VITE_OPENROUTER_API_KEY=your_openrouter_api_key

# Optional: choose the primary/fallback OpenRouter models.
VITE_OPENROUTER_MODEL=qwen/qwen3.6-plus:free
VITE_OPENROUTER_FALLBACK_MODELS=google/gemma-3-27b-it:free

# Optional: direct Gemini fallback when OpenRouter is unavailable or rate limited.
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
